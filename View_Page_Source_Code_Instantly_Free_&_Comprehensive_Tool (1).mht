u003c/div\u003e\n          \u003cdiv style={{display:\"grid\",gridTemplateColumns:\"repeat(7,1fr)\",gap:5,marginBottom:14}}\u003e\n            {Array.from({length:28},(_,i)=\u003ei+1).map(d=\u003e{\n              const sel=days.includes(d);\n              return \u003cdiv key={d} onClick={()=\u003etoggleDay(d)} style={{\n                padding:\"7px 2px\",textAlign:\"center\",borderRadius:7,cursor:\"pointer\",fontSize:11,\n                border:`1px solid ${sel?C.cyan:\"rgba(255,255,255,0.08)\"}`,\n                background:sel?\"rgba(0,229,255,0.18)\":\"rgba(255,255,255,0.03)\",\n                color:sel?C.cyan:\"#888\", fontWeight:sel?700:400,\n                boxShadow:sel?`0 0 8px rgba(0,229,255,0.3)`:\"none\",\n              }}\u003e{d}\u003c/div\u003e;\n            })}\n          \u003c/div\u003e\n          {err\u0026\u0026\u003cdiv style={{color:C.red,fontSize:11,marginBottom:10}}\u003e{err}\u003c/div\u003e}\n          {days.length\u003e0\u0026\u0026\u003cGCard style={{padding:10,marginBottom:14,background:\"rgba(0,229,255,0.06)\"}}\u003e\n            \u003cdiv style={{color:C.cyan,fontSize:11}}\u003e­¤ōģ Withdrawal days: {days.map(d=\u003e`Day ${d}`).join(\" ┬Ę \")}\u003c/div\u003e\n          \u003c/GCard\u003e}\n          \u003cdiv style={{display:\"flex\",gap:8}}\u003e\n            \u003cGBtn onClick={()=\u003esetStep(2)} color=\"#334155\" style={{flex:1}}\u003eŌåÉ BACK\u003c/GBtn\u003e\n            \u003cGBtn onClick={()=\u003es3ok\u0026\u0026onComplete({phone,lp,wp,cbe,days})} disabled={!s3ok} style={{flex:1}} color={C.green}\u003eŌ£ō START EARNING\u003c/GBtn\u003e\n          \u003c/div\u003e\n          \u003cdiv style={{textAlign:\"center\",marginTop:12,color:\"#555\",fontSize:10,letterSpacing:1}}\u003e\n            POWERED BY NIXORA ŌĆó TELEGRAM: @NixoraBot\n          \u003c/div\u003e\n        \u003c/\u003e}\n      \u003c/GCard\u003e\n    \u003c/div\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ HEADER ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction Header({ notifs, setNotifs, lang, setLang }) {\n  const unread = notifs.filter(n=\u003e!n.read).length;\n  return (\n    \u003cdiv style={{\n      display:\"flex\",justifyContent:\"space-between\",alignItems:\"center\",\n      padding:\"12px 18px 8px\",\n      background:\"linear-gradient(to bottom,rgba(6,11,20,0.97),rgba(6,11,20,0.6))\",\n      position:\"sticky\",top:0,zIndex:100,\n    }}\u003e\n      \u003cdiv style={{display:\"flex\",alignItems:\"center\",gap:8}}\u003e\n        \u003cNixoraLogo size={30}/\u003e\n        \u003cspan style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:14,fontWeight:900,letterSpacing:4,color:\"#fff\"}}\u003eNIXORA\u003c/span\u003e\n      \u003c/div\u003e\n      \u003cdiv style={{display:\"flex\",gap:6,alignItems:\"center\"}}\u003e\n        {[[\"EN\",\"English\"],[\"ßŖĀßłø\",\"Amharic\"],[\"ORO\",\"Oromic\"]].map(([code,full])=\u003e(\n          \u003cdiv key={code} onClick={()=\u003esetLang(code)}\n            style={{\n              fontSize:9,padding:\"4px 7px\",borderRadius:6,cursor:\"pointer\",letterSpacing:0.5,\n              border:`1px solid ${lang===code?C.cyan:\"rgba(255,255,255,0.15)\"}`,\n              background:lang===code?\"rgba(0,229,255,0.12)\":\"transparent\",\n              color:lang===code?C.cyan:\"#888\",\n            }}\u003e{code}\u003c/div\u003e\n        ))}\n        \u003cdiv style={{position:\"relative\",marginLeft:4,cursor:\"pointer\"}}\n          onClick={()=\u003esetNotifs(n=\u003en.map(x=\u003e({...x,read:true})))}\u003e\n          \u003cspan style={{fontSize:18}}\u003e­¤öö\u003c/span\u003e\n          {unread\u003e0\u0026\u0026\u003cdiv style={{\n            position:\"absolute\",top:-3,right:-3,background:C.red,borderRadius:\"50%\",\n            width:15,height:15,display:\"flex\",alignItems:\"center\",justifyContent:\"center\",\n            fontSize:8,fontWeight:700,color:\"#fff\",\n          }}\u003e{unread}\u003c/div\u003e}\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ BOTTOM NAV ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction BottomNav({ tab, setTab }) {\n  const tabs = [\n    { id:\"home\",       icon:\"­¤ÅĀ\", label:\"Home\" },\n    { id:\"tasks\",      icon:\"Ō£ģ\", label:\"Tasks\" },\n    { id:\"promotions\", icon:\"­¤ōŻ\", label:\"Promotions\" },\n    { id:\"deposit\",    icon:\"­¤Æ░\", label:\"Deposit\" },\n    { id:\"account\",    icon:\"­¤æż\", label:\"Account\" },\n  ];\n  return (\n    \u003cdiv style={{\n      position:\"fixed\",bottom:0,left:\"50%\",transform:\"translateX(-50%)\",\n      width:\"100%\",maxWidth:430,\n      background:\"rgba(6,11,20,0.97)\",\n      borderTop:\"1px solid rgba(0,229,255,0.15)\",\n      display:\"flex\",zIndex:200,backdropFilter:\"blur(20px)\",\n    }}\u003e\n      {tabs.map(t=\u003e(\n        \u003cdiv key={t.id} onClick={()=\u003esetTab(t.id)} style={{\n          flex:1,padding:\"10px 4px\",textAlign:\"center\",cursor:\"pointer\",\n          borderTop:`2px solid ${tab===t.id?C.cyan:\"transparent\"}`,\n          transition:\"all 0.2s\",\n        }}\u003e\n          \u003cdiv style={{fontSize:18}}\u003e{t.icon}\u003c/div\u003e\n          \u003cdiv style={{\n            fontSize:9,fontWeight:700,letterSpacing:0.5,\n            color:tab===t.id?C.cyan:\"#555\",\n            marginTop:2,fontFamily:\"'Rajdhani',sans-serif\",\n          }}\u003e{t.label}\u003c/div\u003e\n        \u003c/div\u003e\n      ))}\n    \u003c/div\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ HOME TAB ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction HomeTab({ u, earn, setTab }) {\n  const [adCD,setAdCD] = useState(0);\n  const vip = VIP_LEVELS[u.vipLevel-1];\n  useEffect(()=\u003e{\n    if(adCD\u003e0){const t=setTimeout(()=\u003esetAdCD(c=\u003ec-1),1000);return()=\u003eclearTimeout(t);}\n  },[adCD]);\n  const watchAd=()=\u003e{ if(adCD\u003e0)return; earn(vip?Math.round(vip.daily/10):50); setAdCD(30); };\n  const pct = vip ? Math.min(100,Math.round((u.todayEarnings/vip.daily)*100)) : 0;\n\n  return (\n    \u003cdiv style={{padding:\"8px 14px\"}}\u003e\n      {/* Hero balance card */}\n      \u003cGCard glow style={{\n        marginBottom:14,\n        background:\"linear-gradient(135deg,rgba(0,229,255,0.08),rgba(124,58,237,0.08))\",\n        borderColor:C.cyan,\n      }}\u003e\n        \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",alignItems:\"flex-start\"}}\u003e\n          \u003cdiv\u003e\n            \u003cdiv style={{fontSize:10,color:\"#888\",letterSpacing:2}}\u003eCURRENT BALANCE\u003c/div\u003e\n            \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:30,fontWeight:900,color:\"#fff\",marginTop:2}}\u003e\n              {fmt(u.balance)}\n              \u003cspan style={{fontSize:14,color:C.cyan,marginLeft:6}}\u003eETB\u003c/span\u003e\n            \u003c/div\u003e\n            \u003cdiv style={{display:\"flex\",gap:16,marginTop:8}}\u003e\n              \u003cdiv style={{fontSize:11,color:\"#888\"}}\u003eToday: \u003cspan style={{color:C.green,fontWeight:700}}\u003e+{fmt(u.todayEarnings)} ETB\u003c/span\u003e\u003c/div\u003e\n              \u003cdiv style={{fontSize:11,color:\"#888\"}}\u003eTotal: \u003cspan style={{color:C.cyan,fontWeight:700}}\u003e{fmt(u.totalEarnings)} ETB\u003c/span\u003e\u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          \u003cdiv style={{textAlign:\"center\"}}\u003e\n            \u003cdiv style={{fontSize:9,color:\"#666\",letterSpacing:1}}\u003eVIP LEVEL\u003c/div\u003e\n            \u003cdiv style={{\n              width:44,height:44,borderRadius:\"50%\",\n              border:`2px solid ${vip?vip.color:C.border}`,\n              background:\"rgba(0,0,0,0.4)\",\n              display:\"flex\",alignItems:\"center\",justifyContent:\"center\",\n              fontFamily:\"'Orbitron',sans-serif\",fontSize:16,fontWeight:900,\n              color:vip?vip.color:C.cyan,\n              boxShadow:vip?`0 0 14px ${vip.color}66`:\"none\",\n            }}\u003e{u.vipLevel||\"ŌĆö\"}\u003c/div\u003e\n            \u003cdiv style={{fontSize:9,color:vip?vip.color:\"#555\",marginTop:3}}\u003e{vip?vip.name:\"FREE\"}\u003c/div\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n      \u003c/GCard\u003e\n\n      {/* Watch Ad */}\n      \u003cGBtn onClick={watchAd} disabled={adCD\u003e0} full color={adCD\u003e0?C.purple:C.teal}\n        style={{marginBottom:14,padding:16,fontSize:15,letterSpacing:1}}\u003e\n        {adCD\u003e0 ? `ŌÅ│ Next Ad in ${adCD}s` : `­¤ō║ WATCH AD ŌĆö Earn ${vip?Math.round(vip.daily/10):50} ETB`}\n      \u003c/GBtn\u003e\n\n      {/* Quick stats */}\n      \u003cdiv style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr 1fr\",gap:10,marginBottom:14}}\u003e\n        {[\n          {label:\"Daily Target\",val:`${fmt(vip?.daily||0)} ETB`,color:C.cyan},\n          {label:\"Daily Avg\",   val:`${fmt(Math.round(u.totalEarnings/Math.max(1,u.daysActive||1)))} ETB`,color:C.gold},\n          {label:\"Referrals\",   val:u.referrals||0,color:C.purple},\n        ].map((s,i)=\u003e(\n          \u003cGCard key={i} style={{padding:\"12px 10px\",textAlign:\"center\"}}\u003e\n            \u003cdiv style={{fontSize:13,fontWeight:700,color:s.color,fontFamily:\"'Orbitron',sans-serif\"}}\u003e{s.val}\u003c/div\u003e\n            \u003cdiv style={{fontSize:9,color:\"#666\",marginTop:3,letterSpacing:1}}\u003e{s.label}\u003c/div\u003e\n          \u003c/GCard\u003e\n        ))}\n      \u003c/div\u003e\n\n      {/* Progress card */}\n      \u003cGCard style={{marginBottom:14}}\u003e\n        \u003cdiv style={{fontSize:12,fontWeight:700,color:C.cyan,marginBottom:12,letterSpacing:1}}\u003e­¤ōŖ REVENUE STATS\u003c/div\u003e\n        {[\n          {label:\"Today's Progress\",pct,color:C.cyan},\n          {label:\"Monthly Goal\",pct:Math.min(100,Math.round((u.balance/5000)*100)),color:C.teal},\n          {label:\"Task Completion\",pct:Math.min(100,Math.round((u.completedTasks.length/TASKS_LIST.length)*100)),color:C.green},\n        ].map((b,i)=\u003e(\n          \u003cdiv key={i} style={{marginBottom:10}}\u003e\n            \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",marginBottom:4}}\u003e\n              \u003cspan style={{fontSize:11,color:\"#888\"}}\u003e{b.label}\u003c/span\u003e\n              \u003cspan style={{fontSize:11,color:b.color,fontWeight:700}}\u003e{b.pct}%\u003c/span\u003e\n            \u003c/div\u003e\n            \u003cdiv style={{background:\"rgba(255,255,255,0.08)\",borderRadius:4,height:5,overflow:\"hidden\"}}\u003e\n              \u003cdiv style={{width:`${b.pct}%`,height:\"100%\",background:b.color,borderRadius:4,\n                boxShadow:`0 0 8px ${b.color}`,transition:\"width 1s\"}}/\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n        ))}\n      \u003c/GCard\u003e\n\n      {/* Referral */}\n      \u003cGCard\u003e\n        \u003cdiv style={{fontSize:12,fontWeight:700,color:C.purple,marginBottom:10,letterSpacing:1}}\u003e­¤æź REFER \u0026 EARN\u003c/div\u003e\n        \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",alignItems:\"center\",marginBottom:8}}\u003e\n          \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:18,fontWeight:900,color:C.cyan,letterSpacing:3}}\u003e{u.referralCode}\u003c/div\u003e\n          \u003cGBtn small color={C.purple} onClick={()=\u003enavigator.clipboard?.writeText(u.referralCode)}\u003eCOPY\u003c/GBtn\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr\",gap:6}}\u003e\n          {VIP_LEVELS.map(v=\u003e(\n            \u003cdiv key={v.level} style={{fontSize:10,color:\"#888\",padding:\"3px 0\"}}\u003e\n              VIP {v.level}: \u003cspan style={{color:v.color,fontWeight:700}}\u003e{fmt(v.inviteReward)} ETB\u003c/span\u003e\n            \u003c/div\u003e\n          ))}\n        \u003c/div\u003e\n      \u003c/GCard\u003e\n    \u003c/div\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ TASKS TAB ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction TasksTab({ u, earn }) {\n  const isSun = new Date().getDay()===0;\n  const [active,setActive] = useState(null);\n  const [timer,setTimer]   = useState(0);\n  const [survey,setSurvey] = useState(null);\n\n  useEffect(()=\u003e{\n    if(timer\u003e0){const t=setTimeout(()=\u003esetTimer(x=\u003ex-1),1000);return()=\u003eclearTimeout(t);}\n    if(timer===0\u0026\u0026active\u0026\u0026active.type!==\"survey\"){\n      if(active.completing){\n        earn(active.reward);\n        u.setCompletedTasks(prev=\u003e[...prev,active.id]);\n        setActive(null);\n      }\n    }\n  },[timer]);\n\n  const startTask=(task)=\u003e{\n    if(u.completedTasks.includes(task.id))return;\n    if(task.type===\"survey\"){setSurvey({q:0,task});return;}\n    setActive({...task,completing:false});\n    setTimer(task.secs);\n    setTimeout(()=\u003esetActive(a=\u003ea?{...a,completing:true}:null),task.secs*1000);\n  };\n\n  if(isSun) return (\n    \u003cdiv style={{padding:\"40px 14px\",textAlign:\"center\"}}\u003e\n      \u003cdiv style={{fontSize:64,marginBottom:16}}\u003e­¤īģ\u003c/div\u003e\n      \u003cGCard glow style={{padding:32}}\u003e\n        \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:18,color:C.cyan}}\u003eREST DAY\u003c/div\u003e\n        \u003cdiv style={{color:\"#888\",marginTop:10,fontSize:13,lineHeight:1.7}}\u003e\n          Tasks are not available on Sundays.\u003cbr/\u003eTake a break and come back tomorrow!\n        \u003c/div\u003e\n      \u003c/GCard\u003e\n    \u003c/div\u003e\n  );\n\n  if(survey) return (\n    \u003cdiv style={{padding:\"8px 14px\"}}\u003e\n      \u003cGCard glow style={{marginBottom:14}}\u003e\n        \u003cdiv style={{color:C.cyan,fontWeight:700,fontSize:14,marginBottom:4,letterSpacing:1}}\u003e\n          ­¤ōŗ SURVEY ŌĆö Q{survey.q+1}/{SURVEY_QS.length}\n        \u003c/div\u003e\n        \u003cdiv style={{background:\"rgba(255,255,255,0.06)\",borderRadius:8,height:4,overflow:\"hidden\",marginBottom:14}}\u003e\n          \u003cdiv style={{width:`${((survey.q)/SURVEY_QS.length)*100}%`,height:\"100%\",background:C.cyan,borderRadius:8}}/\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{color:\"#fff\",fontSize:14,marginBottom:16,lineHeight:1.5}}\u003e{SURVEY_QS[survey.q].q}\u003c/div\u003e\n        {SURVEY_QS[survey.q].opts.map((opt,i)=\u003e(\n          \u003cdiv key={i} onClick={()=\u003e{\n            const nq=survey.q+1;\n            if(nq\u003e=SURVEY_QS.length){\n              earn(survey.task.reward);\n              u.setCompletedTasks(p=\u003e[...p,survey.task.id]);\n              setSurvey(null);\n            } else setSurvey({...survey,q:nq});\n          }} style={{\n            padding:\"11px 14px\",borderRadius:10,marginBottom:8,cursor:\"pointer\",\n            border:`1px solid ${C.border}`,background:\"rgba(0,229,255,0.04)\",\n            color:\"#ccc\",fontSize:13,\n            transition:\"all 0.15s\",\n          }}\u003e{opt}\u003c/div\u003e\n        ))}\n        \u003cGBtn onClick={()=\u003esetSurvey(null)} color=\"#334155\" small\u003eCancel\u003c/GBtn\u003e\n      \u003c/GCard\u003e\n    \u003c/div\u003e\n  );\n\n  return (\n    \u003cdiv style={{padding:\"8px 14px\"}}\u003e\n      \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",alignItems:\"center\",marginBottom:14}}\u003e\n        \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:14,color:C.cyan,letterSpacing:1}}\u003eDAILY TASKS\u003c/div\u003e\n        \u003cdiv style={{fontSize:10,color:\"#555\",letterSpacing:1}}\u003eRESETS AT MIDNIGHT\u003c/div\u003e\n      \u003c/div\u003e\n\n      {TASKS_LIST.map(task=\u003e{\n        const done=u.completedTasks.includes(task.id);\n        const isAct=active?.id===task.id;\n        return (\n          \u003cGCard key={task.id} style={{marginBottom:10,opacity:done?0.55:1}}\u003e\n            \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",alignItems:\"center\"}}\u003e\n              \u003cdiv style={{display:\"flex\",alignItems:\"center\",gap:12}}\u003e\n                \u003cdiv style={{\n                  width:44,height:44,borderRadius:12,\n                  background:`rgba(0,229,255,0.08)`,\n                  border:`1px solid ${C.border}`,\n                  display:\"flex\",alignItems:\"center\",justifyContent:\"center\",\n                  fontSize:22,\n                }}\u003e{task.icon}\u003c/div\u003e\n                \u003cdiv\u003e\n                  \u003cdiv style={{color:\"#fff\",fontWeight:700,fontSize:13}}\u003e{task.name}\u003c/div\u003e\n                  \u003cdiv style={{color:C.green,fontSize:12,fontWeight:700}}\u003e+{task.reward} ETB\u003c/div\u003e\n                  {task.secs\u003e0\u0026\u0026\u003cdiv style={{color:\"#555\",fontSize:10}}\u003eŌÅ▒ {task.secs}s\u003c/div\u003e}\n                \u003c/div\u003e\n              \u003c/div\u003e\n              \u003cdiv\u003e\n                {done ? \u003cdiv style={{color:C.green,fontSize:20}}\u003eŌ£ō\u003c/div\u003e\n                : isAct ? \u003cdiv style={{color:C.cyan,fontSize:12,fontFamily:\"'Orbitron',sans-serif\"}}\u003e{timer}s\u003c/div\u003e\n                : \u003cGBtn small onClick={()=\u003estartTask(task)} color={C.teal}\u003eSTART\u003c/GBtn\u003e}\n              \u003c/div\u003e\n            \u003c/div\u003e\n            {isAct\u0026\u0026task.secs\u003e0\u0026\u0026(\n              \u003cdiv style={{marginTop:10}}\u003e\n                \u003cdiv style={{background:\"rgba(255,255,255,0.08)\",borderRadius:4,height:4,overflow:\"hidden\"}}\u003e\n                  \u003cdiv style={{\n                    width:`${((task.secs-timer)/task.secs)*100}%`,\n                    height:\"100%\",background:C.cyan,borderRadius:4,transition:\"width 1s\",\n                  }}/\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            )}\n          \u003c/GCard\u003e\n        );\n      })}\n\n      \u003cGCard style={{background:\"rgba(16,185,129,0.05)\",borderColor:\"rgba(16,185,129,0.2)\"}}\u003e\n        \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",marginBottom:6}}\u003e\n          \u003cspan style={{color:C.green,fontWeight:700,fontSize:13,letterSpacing:1}}\u003eTODAY'S PROGRESS\u003c/span\u003e\n          \u003cspan style={{color:C.green,fontSize:13}}\u003e{u.completedTasks.length}/{TASKS_LIST.length}\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{background:\"rgba(255,255,255,0.08)\",borderRadius:4,height:6,overflow:\"hidden\"}}\u003e\n          \u003cdiv style={{\n            width:`${(u.completedTasks.length/TASKS_LIST.length)*100}%`,\n            height:\"100%\",background:C.green,borderRadius:4,transition:\"width 0.5s\",\n          }}/\u003e\n        \u003c/div\u003e\n      \u003c/GCard\u003e\n    \u003c/div\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ PROMOTIONS TAB ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction PromotionsTab({ u, earn }) {\n  const [sub,setSub]=useState(\"boosters\");\n  const subs=[[\"boosters\",\"­¤ōŻ Boosters\"],[\"cards\",\"­¤āÅ Cards\"],[\"wheel\",\"­¤ÄĪ Wheel\"],[\"invest\",\"­¤ōł Invest\"]];\n  return (\n    \u003cdiv style={{padding:\"8px 14px\"}}\u003e\n      \u003cdiv style={{display:\"flex\",gap:7,marginBottom:14,overflowX:\"auto\",paddingBottom:2}}\u003e\n        {subs.map(([id,label])=\u003e(\n          \u003cdiv key={id} onClick={()=\u003esetSub(id)} style={{\n            padding:\"8px 14px\",borderRadius:20,fontSize:11,fontWeight:700,\n            cursor:\"pointer\",whiteSpace:\"nowrap\",letterSpacing:0.5,\n            background:sub===id?\"rgba(0,229,255,0.15)\":\"rgba(255,255,255,0.04)\",\n            border:`1px solid ${sub===id?C.cyan:\"rgba(255,255,255,0.08)\"}`,\n            color:sub===id?C.cyan:\"#666\",\n          }}\u003e{label}\u003c/div\u003e\n        ))}\n      \u003c/div\u003e\n      {sub===\"boosters\"\u0026\u0026\u003cBoostersTab u={u} earn={earn}/\u003e}\n      {sub===\"cards\"\u0026\u0026\u003cCardGame u={u} earn={earn}/\u003e}\n      {sub===\"wheel\"\u0026\u0026\u003cLuckyWheel u={u} earn={earn}/\u003e}\n      {sub===\"invest\"\u0026\u0026\u003cInvestTab u={u}/\u003e}\n    \u003c/div\u003e\n  );\n}\n\nfunction BoostersTab({ u, earn }) {\n  const boosters=[\n    {name:\"TikTok Promotion Booster\", icon:\"­¤ÄĄ\", reward:2500, completion:75},\n    {name:\"Google Ads Booster\",       icon:\"­¤ōŻ\", reward:2500, completion:75},\n    {name:\"Follow Booster\",           icon:\"­¤æź\", reward:1200, completion:40},\n    {name:\"Like Booster\",             icon:\"­¤æŹ\", reward:1200, completion:75},\n    {name:\"Share Booster\",            icon:\"­¤öŚ\", reward:1200, completion:40},\n    {name:\"Video View Booster\",       icon:\"Ō¢Č’ĖÅ\", reward:1800, completion:60},\n    {name:\"Creator Engagement\",       icon:\"­¤Ä¼\", reward:1800, completion:60},\n    {name:\"Referral Booster\",         icon:\"­¤æż\", reward:1200, completion:0},\n    {name:\"Campaign Booster\",         icon:\"­¤ōŖ\", reward:1200, completion:75},\n  ];\n  return (\n    \u003c\u003e\n      \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:13,color:C.cyan,marginBottom:12,letterSpacing:1}}\u003eDAILY BOOSTER TASKS\u003c/div\u003e\n      {boosters.map((b,i)=\u003e(\n        \u003cGCard key={i} style={{marginBottom:9}}\u003e\n          \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",alignItems:\"center\"}}\u003e\n            \u003cdiv style={{display:\"flex\",gap:10,alignItems:\"center\"}}\u003e\n              \u003cspan style={{fontSize:20}}\u003e{b.icon}\u003c/span\u003e\n              \u003cdiv\u003e\n                \u003cdiv style={{fontSize:12,fontWeight:700,color:\"#ccc\"}}\u003e{b.name}\u003c/div\u003e\n                \u003cdiv style={{fontSize:11,color:C.cyan}}\u003e+{fmt(b.reward)} TCN\u003c/div\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n            \u003cGBtn small color={C.purple}\u003eBOOST\u003c/GBtn\u003e\n          \u003c/div\u003e\n          \u003cdiv style={{marginTop:8}}\u003e\n            \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\",fontSize:9,color:\"#555\",marginBottom:3,letterSpacing:1}}\u003e\n              \u003cspan\u003eCOMPLETION\u003c/span\u003e\u003cspan\u003e{b.completion}%\u003c/span\u003e\n            \u003c/div\u003e\n            \u003cdiv style={{background:\"rgba(255,255,255,0.07)\",borderRadius:3,height:4,overflow:\"hidden\"}}\u003e\n              \u003cdiv style={{width:`${b.completion}%`,height:\"100%\",\n                background:`linear-gradient(90deg,${C.purple},${C.cyan})`,borderRadius:3}}/\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n        \u003c/GCard\u003e\n      ))}\n      \u003cGCard style={{marginTop:14,background:\"rgba(124,58,237,0.07)\",borderColor:\"rgba(124,58,237,0.25)\"}}\u003e\n        \u003cdiv style={{color:C.purple,fontWeight:700,fontSize:13,marginBottom:8,letterSpacing:1}}\u003e­¤ō× CONTACT FOR PROMOTIONS\u003c/div\u003e\n        \u003cdiv style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr\",gap:8}}\u003e\n          {[\"Promotion Request\",\"Campaign Partnership\",\"Influencer Collaboration\",\"Premium Packages\"].map((x,i)=\u003e(\n            \u003cGBtn key={i} small color=\"#334155\" style={{width:\"100%\",textAlign:\"center\"}}\u003e{x}\u003c/GBtn\u003e\n          ))}\n        \u003c/div\u003e\n        \u003cGBtn full color={C.purple} style={{marginTop:10}}\n          onClick={()=\u003ewindow.open(\"https://t.me/NixoraBot\",\"_blank\")}\u003e\n          ­¤ō▒ Chat with Support @NixoraBot\n        \u003c/GBtn\u003e\n      \u003c/GCard\u003e\n    \u003c/\u003e\n  );\n}\n\nfunction CardGame({ u, earn }) {\n  const [cards,setCards]=useState([]);\n  const [res,setRes]    =useState(null);\n  const [flip,setFlip]  =useState(false);\n\n  const draw=()=\u003e{\n    if(u.cardDraws\u003c=0)return;\n    const c1=CARD_VALUES[Math.floor(Math.random()*CARD_VALUES.length)];\n    const c2=CARD_VALUES[Math.floor(Math.random()*CARD_VALUES.length)];\n    const s1=CARD_SUITS[Math.floor(Math.random()*4)];\n    const s2=CARD_SUITS[Math.floor(Math.random()*4)];\n    setCards([{v:c1,s:s1},{v:c2,s:s2}]); setFlip(false); setRes(null);\n    u.setCardDraws(d=\u003ed-1);\n    setTimeout(()=\u003e{\n      setFlip(true);\n      if(c1===c2){\n        const rw=CARD_MATCH_REWARDS[c1]||100;\n        setRes({win:true,msg:`­¤Äē MATCH! Both ${c1}s ŌĆö Win ${fmt(rw)} ETB!`,rw});\n        earn(rw);\n      } else setRes({win:false,msg:\"No match. Try again next draw!\"});\n    },900);\n  };\n\n  return (\n    \u003cGCard glow\u003e\n      \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",color:C.gold,fontSize:14,marginBottom:6,letterSpacing:1}}\u003eLUCKY CARD DRAW\u003c/div\u003e\n      \u003cdiv style={{color:\"#888\",fontSize:11,marginBottom:18,lineHeight:1.6}}\u003e\n        Draw 2 cards. Matching cards win big ETB rewards! Earn draws by referring new members.\n        Draws remaining: \u003cspan style={{color:C.cyan,fontWeight:700}}\u003e{u.cardDraws}\u003c/span\u003e\n      \u003c/div\u003e\n\n      \u003cstyle\u003e{`\n        @keyframes cardFlip{0%{transform:rotateY(0deg);}50%{transform:rotateY(90deg);}100%{transform:rotateY(0deg);}}\n      `}\u003c/style\u003e\n\n      \u003cdiv style={{display:\"flex\",gap:20,justifyContent:\"center\",marginBottom:22}}\u003e\n        {[0,1].map(i=\u003e{\n          const card=cards[i]; const red=card?.s===\"ŌÖź\"||card?.s===\"ŌÖ”\";\n          return (\n            \u003cdiv key={i} style={{\n              width:88,height:128,borderRadius:12,\n              background:flip\u0026\u0026card?\"linear-gradient(145deg,#fff,#f0f0f0)\":\"linear-gradient(135deg,#1a2744,#2a3a5c)\",\n              border:`2px solid ${flip\u0026\u0026card?(red?\"#dc2626\":C.border):C.cyan}`,\n              display:\"flex\",flexDirection:\"column\",alignItems:\"center\",justifyContent:\"center\",\n              fontSize:flip\u0026\u0026card?32:28,\n              color:flip\u0026\u0026card?(red?\"#dc2626\":\"#111\"):C.cyan,\n              fontWeight:900,\n              boxShadow:`0 0 20px rgba(0,229,255,0.25)`,\n              animation:flip\u0026\u0026card?\"cardFlip 0.9s ease\":\"none\",\n            }}\u003e\n              {flip\u0026\u0026card?\u003c\u003e\u003cdiv style={{fontSize:22,fontWeight:900}}\u003e{card.v}\u003c/div\u003e\u003cdiv\u003e{card.s}\u003c/div\u003e\u003c/\u003e:\"­¤éĀ\"}\n            \u003c/div\u003e\n          );\n        })}\n      \u003c/div\u003e\n\n      {res\u0026\u0026\u003cdiv style={{\n        textAlign:\"center\",marginBottom:14,padding:12,borderRadius:10,\n        background:res.win?\"rgba(16,185,129,0.12)\":\"rgba(100,100,100,0.08)\",\n        border:`1px solid ${res.win?C.green:\"#334155\"}`,\n        color:res.win?C.green:\"#888\",fontSize:13,fontWeight:700,\n      }}\u003e{res.msg}\u003c/div\u003e}\n\n      \u003cGBtn full onClick={draw} disabled={u.cardDraws\u003c=0} color={C.gold}\u003e\n        {u.cardDraws\u003e0?\"­¤āÅ DRAW CARDS\":\"Refer friends for more draws\"}\n      \u003c/GBtn\u003e\n      \u003cdiv style={{marginTop:12,fontSize:10,color:\"#555\",textAlign:\"center\",lineHeight:1.8}}\u003e\n        Match rewards: A=1,000 ┬Ę K=800 ┬Ę Q=600 ┬Ę J=500 ┬Ę 10=400 ┬Ę 9=300 ┬Ę 8=250 ┬Ę 7=200 ETB\n      \u003c/div\u003e\n    \u003c/GCard\u003e\n  );\n}\n\nfunction LuckyWheel({ u, earn }) {\n  const [spinning,setSpinning]=useState(false);\n  const [angle,setAngle]      =useState(0);\n  const [prize,setPrize]      =useState(null);\n  const sz=360/WHEEL_PRIZES.length;\n  const colors=[C.cyan,C.purple,\"#334155\",C.gold,C.teal,C.red,C.green,\"#475569\"];\n\n  const spin=()=\u003e{\n    if(spinning||u.wheelSpins\u003c=0)return;\n    setSpinning(true); setPrize(null);\n    u.setWheelSpins(s=\u003es-1);\n    const idx=Math.floor(Math.random()*WHEEL_PRIZES.length);\n    const target=360*6+(sz*idx);\n    setAngle(a=\u003ea+target);\n    setTimeout(()=\u003e{\n      setSpinning(false);\n      const rw=WHEEL_PRIZES[idx];\n      setPrize({amount:rw,idx});\n      if(rw\u003e0)earn(rw);\n    },4200);\n  };\n\n  return (\n    \u003cGCard glow style={{textAlign:\"center\"}}\u003e\n      \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",color:C.gold,fontSize:14,marginBottom:6,letterSpacing:1}}\u003eLUCKY SPIN\u003c/div\u003e\n      \u003cdiv style={{color:\"#888\",fontSize:11,marginBottom:20}}\u003e\n        Spin for ETB rewards! Earn spins by referring members.\n        Spins left: \u003cspan style={{color:C.gold,fontWeight:700}}\u003e{u.wheelSpins}\u003c/span\u003e\n      \u003c/div\u003e\n\n      \u003cdiv style={{position:\"relative\",width:220,height:240,margin:\"0 auto 20px\"}}\u003e\n        \u003cdiv style={{position:\"absolute\",top:0,left:\"50%\",transform:\"translateX(-50%)\",\n          zIndex:10,fontSize:26,filter:`drop-shadow(0 0 8px ${C.gold})`}}\u003eŌ¢╝\u003c/div\u003e\n        \u003csvg width={220} height={220} style={{\n          transform:`rotate(${angle}deg)`,\n          transition:spinning?`transform 4.2s cubic-bezier(0.17,0.67,0.12,0.99)`:\"none\",\n          marginTop:20,\n        }}\u003e\n          {WHEEL_PRIZES.map((pr,i)=\u003e{\n            const a0=(i*sz-90)*(Math.PI/180);\n            const a1=((i+1)*sz-90)*(Math.PI/180);\n            const x1=110+100*Math.cos(a0), y1=110+100*Math.sin(a0);\n            const x2=110+100*Math.cos(a1), y2=110+100*Math.sin(a1);\n            const am=((i+0.5)*sz-90)*(Math.PI/180);\n            const tx=110+65*Math.cos(am), ty=110+65*Math.sin(am);\n            return (\n              \u003cg key={i}\u003e\n                \u003cpath d={`M110,110 L${x1},${y1} A100,100 0 0,1 ${x2},${y2} Z`}\n                  fill={colors[i]} stroke=\"#060b14\" strokeWidth=\"2\" opacity=\"0.88\"/\u003e\n                \u003ctext x={tx} y={ty} textAnchor=\"middle\" dominantBaseline=\"middle\"\n                  fill=\"#fff\" fontSize=\"11\" fontWeight=\"700\"\n                  transform={`rotate(${(i+0.5)*sz},${tx},${ty})`}\u003e\n                  {pr\u003e0?pr:\"Ō£Ś\"}\n                \u003c/text\u003e\n              \u003c/g\u003e\n            );\n          })}\n          \u003ccircle cx=\"110\" cy=\"110\" r=\"20\" fill=\"#060b14\" stroke={C.cyan} strokeWidth=\"2\"/\u003e\n          \u003ctext x=\"110\" y=\"114\" textAnchor=\"middle\" fill={C.cyan} fontSize=\"9\" fontWeight=\"700\"\u003eSPIN\u003c/text\u003e\n        \u003c/svg\u003e\n      \u003c/div\u003e\n\n      {prize!==null\u0026\u0026\u003cdiv style={{\n        marginBottom:14,padding:12,borderRadius:10,\n        background:prize.amount\u003e0?\"rgba(16,185,129,0.12)\":\"rgba(100,100,100,0.08)\",\n        border:`1px solid ${prize.amount\u003e0?C.green:\"#334155\"}`,\n        color:prize.amount\u003e0?C.green:\"#888\",fontSize:14,fontWeight:700,\n      }}\u003e{prize.amount\u003e0?`­¤Äē You won ${prize.amount} ETB!`:\"Better luck next time!\"}\u003c/div\u003e}\n\n      \u003cGBtn full onClick={spin} disabled={spinning||u.wheelSpins\u003c=0} color={C.gold}\u003e\n        {spinning?\"­¤ÄĪ Spinning...\":u.wheelSpins\u003e0?\"­¤ÄĪ SPIN THE WHEEL!\":\"No spins remaining\"}\n      \u003c/GBtn\u003e\n    \u003c/GCard\u003e\n  );\n}\n\nfunction InvestTab({ u }) {\n  const [sel,setSel]=useState(null);\n  const [amt,setAmt]=useState(\"\");\n  const [pw,setPw]  =useState(\"\");\n  const [err,setErr]=useState(\"\");\n  const [ok,setOk]  =useState(\"\");\n  const [cat,setCat]=useState(\"All\");\n\n  const cats=[\"All\",\"Bonds\",\"Market\",\"Tech\",\"Materials\",\"Funds\",\"Crypto\",\"Firms\"];\n  const filtered=cat===\"All\"?INVESTMENTS:INVESTMENTS.filter(x=\u003ex.cat===cat);\n\n  const doInvest=()=\u003e{\n    setErr(\"\");setOk(\"\");\n    if(!sel){setErr(\"Select an investment\");return;}\n    if(pw!==u.wp){setErr(\"Incorrect investment password\");return;}\n    const a=Number(amt);\n    if(!a||a\u003csel.min){setErr(`Minimum investment: ${fmt(sel.min)} ETB`);return;}\n    if(a\u003eu.balance){setErr(\"Insufficient balance\");return;}\n    u.setBalance(b=\u003eb-a);\n    u.setInvestments(inv=\u003e[...inv,{id:Date.now(),name:sel.name,icon:sel.icon,amount:a,roi:sel.roi,days:sel.days,\n      start:new Date().toLocaleDateString(),returns:Math.round(a*(1+sel.roi/100))}]);\n    setOk(`Ō£ō Invested ${fmt(a)} ETB in ${sel.name}! Expected return: ${fmt(Math.round(a*(1+sel.roi/100)))} ETB in ${sel.days} days`);\n    setAmt(\"\");setPw(\"\");setSel(null);\n  };\n\n  return (\n    \u003c\u003e\n      {u.investments.length\u003e0\u0026\u0026(\n        \u003cGCard style={{marginBottom:14,background:\"rgba(16,185,129,0.04)\",borderColor:\"rgba(16,185,129,0.2)\"}}\u003e\n          \u003cdiv style={{color:C.green,fontWeight:700,fontSize:13,marginBottom:10,letterSpacing:1}}\u003e­¤ōł ACTIVE INVESTMENTS\u003c/div\u003e\n          {u.investments.map(inv=\u003e(\n            \u003cdiv key={inv.id} style={{borderBottom:\"1px solid rgba(255,255,255,0.05)\",paddingBottom:8,marginBottom:8}}\u003e\n              \u003cdiv style={{display:\"flex\",justifyContent:\"space-between\"}}\u003e\n                \u003cspan style={{color:\"#ccc\",fontSize:12}}\u003e{inv.icon} {inv.name}\u003c/span\u003e\n                \u003cspan style={{color:C.green,fontSize:11,fontWeight:700}}\u003e{inv.roi}% ROI\u003c/span\u003e\n            