:root { --bg-primary: #0a0a0a; --bg-surface: #141414; --bg-elevated: #1f1f1f; --accent: #5cff85; --accent-glow: #5cff8559; --accent-muted: #5cff8526; --success: #10b981; --warning: #f59e0b; --danger: #f36; --text-primary: #fafafa; --text-secondary: #a3a3a3; --text-muted: #737373; --border: #ffffff1f; --glass-bg: #ffffff08; --glass-border: #ffffff1a; --glass-highlight: #fff3; --radius-sm: 8px; --radius-md: 12px; --radius-lg: 16px; --radius-xl: 24px; }

* { box-sizing: border-box; }

html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

body { background: var(--bg-primary); color: var(--text-primary); min-height: 100vh; margin: 0px; font-family: "Plus Jakarta Sans", system-ui, sans-serif; line-height: 1.6; }

h1, h2, h3, h4, h5, h6 { font-family: Outfit, system-ui, sans-serif; }

a { color: var(--accent); text-decoration: none; transition: opacity 0.2s; }

a:hover { opacity: 0.85; }

code, pre { font-family: "JetBrains Mono", monospace; }

.glass { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: var(--radius-lg); }

.glass-card { border: 1px solid var(--glass-border); border-radius: var(--radius-lg); background: linear-gradient(135deg, rgba(30, 30, 30, 0.4), rgba(15, 15, 15, 0.6)); transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s; }

.glass-card:hover { border-color: var(--glass-highlight); transform: translateY(-2px); box-shadow: rgba(0, 0, 0, 0.3) 0px 8px 32px; }

.glow-accent { box-shadow: 0 0 20px var(--accent-glow), 0 0 60px #5cff851a; }

.glow-text { text-shadow: 0 0 20px var(--accent-glow); }

.bento-grid { grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.25rem; display: grid; }

.bento-card { backdrop-filter: blur(12px); border: 1px solid var(--border); border-radius: var(--radius-lg); background: linear-gradient(135deg, rgba(30, 41, 59, 0.9), rgba(15, 23, 42, 0.7)); padding: 1.5rem; transition: 0.3s; position: relative; overflow: hidden; }

.bento-card::before { content: ""; background: linear-gradient(90deg, transparent, var(--accent-glow), transparent); opacity: 0; height: 1px; transition: opacity 0.3s; position: absolute; top: 0px; left: 0px; right: 0px; }

.bento-card:hover { border-color: var(--glass-highlight); transform: translateY(-2px); box-shadow: rgba(0, 0, 0, 0.4) 0px 12px 40px; }

.bento-card:hover::before { opacity: 1; }

.bento-span-2 { grid-column: span 2; }

.bento-span-row-2 { grid-row: span 2; }

.grade-badge { border-radius: var(--radius-md); justify-content: center; align-items: center; width: 48px; height: 48px; font-family: "JetBrains Mono", monospace; font-size: 1.25rem; font-weight: 800; display: inline-flex; }

.grade-a-plus, .grade-a { color: var(--success); background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3); }

.grade-b { color: var(--accent); background: rgba(34, 211, 238, 0.15); border: 1px solid rgba(34, 211, 238, 0.3); }

.grade-c { color: var(--warning); background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.3); }

.grade-d, .grade-f { color: var(--danger); background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); }

::-webkit-scrollbar { width: 8px; height: 8px; }

::-webkit-scrollbar-track { background: var(--bg-primary); }

::-webkit-scrollbar-thumb { background: var(--bg-elevated); border-radius: 4px; }

::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

@keyframes fadeInUp { 
  0% { opacity: 0; transform: translateY(20px); }
  100% { opacity: 1; transform: translateY(0px); }
}

@keyframes pulse-glow { 
  0%, 100% { box-shadow: 0 0 20px var(--accent-glow); }
  50% { box-shadow: 0 0 40px var(--accent-glow), 0 0 80px #22d3ee26; }
}

@keyframes shimmer { 
  0% { background-position: -200% 0px; }
  100% { background-position: 200% 0px; }
}

.animate-fadeInUp { animation: 0.6s ease-out 0s 1 normal forwards running fadeInUp; }

.animate-pulse-glow { animation: 3s ease-in-out 0s infinite normal none running pulse-glow; }

.animate-shimmer { background: linear-gradient(90deg, rgba(0, 0, 0, 0), rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0)) 0px 0px / 200% 100%; animation: 2s ease 0s infinite normal none running shimmer; }

.container-main { max-width: 1280px; margin: 0px auto; padding: 0px 1.5rem; }

.section { padding: 5rem 0px; }

.section-sm { padding: 3rem 0px; }

.ad-slot { border: 1px dashed var(--border); border-radius: var(--radius-md); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; background: rgba(30, 41, 59, 0.5); justify-content: center; align-items: center; min-height: 250px; font-size: 0.75rem; display: flex; }

@media (max-width: 768px) {
  .bento-grid { grid-template-columns: 1fr; }
  .bento-span-2 { grid-column: span 1; }
  .section { padding: 3rem 0px; }
  .container-main { padding: 0px 1rem; }
