r:inv.color,fontWeight:700}}\u003e{inv.roi}% ROI\u003c/div\u003e\n            \u003cdiv style={{fontSize:10,color:\"#666\"}}\u003e{inv.days} days\u003c/div\u003e\n            \u003cdiv style={{fontSize:10,color:\"#888\",marginTop:4}}\u003eMin: {fmt(inv.min)} ETB\u003c/div\u003e\n            \u003cdiv style={{\n              display:\"inline-block\",fontSize:9,padding:\"2px 7px\",borderRadius:6,marginTop:5,\n              background:inv.risk===\"Low\"?\"rgba(16,185,129,0.15)\":inv.risk===\"Med\"?\"rgba(245,158,11,0.15)\":\"rgba(239,68,68,0.15)\",\n              color:inv.risk===\"Low\"?C.green:inv.risk===\"Med\"?C.gold:C.red,\n            }}\u003e{inv.risk} Risk\u003c/div\u003e\n          \u003c/div\u003e\n        ))}\n      \u003c/div\u003e\n\n      {sel\u0026\u0026(\n        \u003cGCard style={{marginBottom:12,borderColor:sel.color}}\u003e\n          \u003cdiv style={{color:sel.color,fontWeight:700,fontSize:13,marginBottom:12}}\u003e{sel.icon} Invest in {sel.name}\u003c/div\u003e\n          \u003cGInput label={`Amount (min ${fmt(sel.min)} ETB)`} value={amt} onChange={setAmt} type=\"number\" placeholder={`${sel.min}`}/\u003e\n          \u003cGInput label=\"Investment Password\" value={pw} onChange={setPw} type=\"password\" placeholder=\"ŌĆóŌĆóŌĆóŌĆóŌĆóŌĆóŌĆóŌĆó\"/\u003e\n          {err\u0026\u0026\u003cdiv style={{color:C.red,fontSize:11,marginBottom:8}}\u003e{err}\u003c/div\u003e}\n          {ok\u0026\u0026\u003cdiv style={{color:C.green,fontSize:11,marginBottom:8,padding:8,borderRadius:8,background:\"rgba(16,185,129,0.08)\"}}\u003e{ok}\u003c/div\u003e}\n          \u003cGBtn full onClick={doInvest} color={sel.color}\u003eCONFIRM INVESTMENT\u003c/GBtn\u003e\n        \u003c/GCard\u003e\n      )}\n    \u003c/\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ DEPOSIT TAB ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction DepositTab({ u }) {\n  const [pm,setPm]=useState(null);\n  const [amt,setAmt]=useState(\"\");\n  const [done,setDone]=useState(false);\n\n  const submit=()=\u003e{\n    if(!pm||!amt)return;\n    setDone(true);\n    setTimeout(()=\u003esetDone(false),4000);\n  };\n\n  return (\n    \u003cdiv style={{padding:\"8px 14px\"}}\u003e\n      \u003cGCard glow style={{marginBottom:14,background:\"linear-gradient(135deg,rgba(0,229,255,0.07),rgba(124,58,237,0.07))\"}}\u003e\n        \u003cdiv style={{fontSize:10,color:\"#888\",letterSpacing:2}}\u003eAVAILABLE BALANCE\u003c/div\u003e\n        \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:28,fontWeight:900,color:C.cyan}}\u003e\n          {fmt(u.balance)} \u003cspan style={{fontSize:14}}\u003eETB\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr\",gap:10,marginTop:10,fontSize:10,color:\"#666\"}}\u003e\n          {[[\"Pending Payments\",\"ŌÜÖ’ĖÅ\"],[\"Successful Deposits\",\"Ō£ģ\"]].map(([l,ic])=\u003e(\n            \u003cGCard key={l} style={{padding:8,textAlign:\"center\"}}\u003e\n              \u003cdiv style={{fontSize:16}}\u003e{ic}\u003c/div\u003e\n              \u003cdiv style={{marginTop:4}}\u003e{l}\u003c/div\u003e\n            \u003c/GCard\u003e\n          ))}\n        \u003c/div\u003e\n      \u003c/GCard\u003e\n\n      \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:12,color:C.cyan,marginBottom:12,letterSpacing:1}}\u003eSELECT PAYMENT METHOD\u003c/div\u003e\n\n      {PAYMENTS.map(p=\u003e(\n        \u003cdiv key={p.id} onClick={()=\u003esetPm(p)} style={{\n          display:\"flex\",justifyContent:\"space-between\",alignItems:\"center\",\n          padding:\"11px 14px\",borderRadius:12,marginBottom:8,cursor:\"pointer\",\n          background:pm?.id===p.id?\"rgba(0,229,255,0.09)\":\"rgba(255,255,255,0.02)\",\n          border:`1px solid ${pm?.id===p.id?C.cyan:\"rgba(255,255,255,0.07)\"}`,\n          transition:\"all 0.2s\",\n        }}\u003e\n          \u003cdiv style={{display:\"flex\",alignItems:\"center\",gap:12}}\u003e\n            \u003cspan style={{fontSize:20}}\u003e{p.emoji}\u003c/span\u003e\n            \u003cdiv\u003e\n              \u003cdiv style={{fontSize:12,fontWeight:700,color:\"#ccc\"}}\u003e{p.name}\u003c/div\u003e\n              \u003cdiv style={{fontSize:10,color:\"#555\"}}\u003eLimit: {fmt(p.limit)} ETB\u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n          {pm?.id===p.id\u0026\u0026\u003cspan style={{color:C.cyan,fontWeight:700}}\u003eŌ£ō\u003c/span\u003e}\n        \u003c/div\u003e\n      ))}\n\n      {pm\u0026\u0026(\n        \u003cGCard style={{marginBottom:14,borderColor:C.cyan}}\u003e\n          \u003cdiv style={{fontWeight:700,color:C.cyan,fontSize:13,marginBottom:12}}\u003e{pm.emoji} {pm.name}\u003c/div\u003e\n          {pm.account\u0026\u0026(\n            \u003cGCard style={{marginBottom:12,background:\"rgba(0,229,255,0.06)\"}}\u003e\n              \u003cdiv style={{fontSize:10,color:\"#888\",letterSpacing:1}}\u003eACCOUNT NUMBER\u003c/div\u003e\n              \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:18,fontWeight:700,color:\"#fff\",letterSpacing:3,marginTop:4}}\u003e{pm.account}\u003c/div\u003e\n              \u003cGBtn small color={C.purple} style={{marginTop:8}} onClick={()=\u003enavigator.clipboard?.writeText(pm.account||\"\")}\u003e\n                ­¤ōŗ COPY NUMBER\n              \u003c/GBtn\u003e\n            \u003c/GCard\u003e\n          )}\n\n          {/* QR */}\n          \u003cdiv style={{\n            width:110,height:110,margin:\"0 auto 12px\",\n            background:\"#fff\",borderRadius:10,\n            display:\"flex\",alignItems:\"center\",justifyContent:\"center\",\n            fontSize:70,border:`2px solid ${C.cyan}`,\n          }}\u003eŌ¢”\u003c/div\u003e\n          \u003cdiv style={{fontSize:10,color:\"#666\",textAlign:\"center\",marginBottom:12,letterSpacing:1}}\u003eQR CODE PAYMENT\u003c/div\u003e\n\n          \u003cGInput label=\"Deposit Amount (ETB)\" value={amt} onChange={setAmt} type=\"number\" placeholder=\"Enter amount\"/\u003e\n\n          {/* Upload */}\n          \u003cdiv style={{\n            border:`2px dashed rgba(0,229,255,0.25)`,borderRadius:12,\n            padding:16,textAlign:\"center\",marginBottom:12,cursor:\"pointer\",\n          }}\u003e\n            \u003cdiv style={{fontSize:28,marginBottom:6}}\u003e­¤ōĘ\u003c/div\u003e\n            \u003cdiv style={{fontSize:12,color:\"#888\"}}\u003eUpload Payment Screenshot\u003c/div\u003e\n            \u003cdiv style={{fontSize:10,color:\"#555\",marginTop:4}}\u003eRequired for verification\u003c/div\u003e\n          \u003c/div\u003e\n\n          {/* Status */}\n          \u003cdiv style={{display:\"flex\",alignItems:\"center\",gap:8,marginBottom:12,\n            padding:\"8px 12px\",borderRadius:8,background:\"rgba(16,185,129,0.07)\",border:\"1px solid rgba(16,185,129,0.2)\"}}\u003e\n            \u003cspan style={{color:C.green,fontSize:14}}\u003e­¤öÆ\u003c/span\u003e\n            \u003cspan style={{fontSize:11,color:\"#888\"}}\u003eTransaction Status: \u003cspan style={{color:C.green,fontWeight:700}}\u003eSecure\u003c/span\u003e\u003c/span\u003e\n          \u003c/div\u003e\n\n          {done?(\n            \u003cGCard style={{textAlign:\"center\",background:\"rgba(16,185,129,0.1)\",borderColor:C.green}}\u003e\n              \u003cdiv style={{color:C.green,fontWeight:700,fontSize:14}}\u003eŌ£ō Deposit Submitted!\u003c/div\u003e\n              \u003cdiv style={{color:\"#888\",fontSize:11,marginTop:6}}\u003eVerify approval on Telegram @NixoraBot\u003c/div\u003e\n            \u003c/GCard\u003e\n          ):(\n            \u003cGBtn full onClick={submit} color={C.teal}\u003eCONFIRM DEPOSIT\u003c/GBtn\u003e\n          )}\n        \u003c/GCard\u003e\n      )}\n\n      {/* Payment verification */}\n      \u003cGCard style={{marginBottom:14,background:\"rgba(0,229,255,0.03)\"}}\u003e\n        \u003cdiv style=