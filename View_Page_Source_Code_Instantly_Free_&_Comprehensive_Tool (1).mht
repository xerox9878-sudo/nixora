                  fontSize:18,\n                }}\u003e{[\"­¤źē\",\"­¤źł\",\"­¤źć\",\"­¤ÆÄ\",\"­¤ææ\"][i]}\u003c/div\u003e\n                \u003cdiv\u003e\n                  \u003cdiv style={{fontSize:14,fontWeight:700,color:active?v.color:\"#ccc\"}}\u003eVIP {v.level} ŌĆö {v.name}\u003c/div\u003e\n                  {active\u0026\u0026\u003cdiv style={{fontSize:10,color:C.green,letterSpacing:1}}\u003eŌ£ō YOUR CURRENT LEVEL\u003c/div\u003e}\n                \u003c/div\u003e\n              \u003c/div\u003e\n              {!active\u0026\u0026u.vipLevel\u003cv.level\u0026\u0026(\n                \u003cGBtn small color={v.color}\u003eUPGRADE\u003c/GBtn\u003e\n              )}\n            \u003c/div\u003e\n            \u003cdiv style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr 1fr 1fr\",gap:8,fontSize:10}}\u003e\n              {[\n                {l:\"Recharge\",v:`${fmt(v.recharge)} ETB`,c:C.gold},\n                {l:\"Daily\",v:`${fmt(v.daily)} ETB`,c:C.green},\n                {l:\"Annual\",v:`${fmt(v.annual)} ETB`,c:C.cyan},\n                {l:\"Invite\",v:`${fmt(v.inviteReward)} ETB`,c:v.color},\n              ].map((s,j)=\u003e(\n                \u003cdiv key={j} style={{textAlign:\"center\"}}\u003e\n                  \u003cdiv style={{color:s.c,fontWeight:700,fontSize:11}}\u003e{s.v}\u003c/div\u003e\n                  \u003cdiv style={{color:\"#555\",marginTop:2}}\u003e{s.l}\u003c/div\u003e\n                \u003c/div\u003e\n              ))}\n            \u003c/div\u003e\n          \u003c/GCard\u003e\n        );\n      })}\n    \u003c/\u003e\n  );\n}\n\nfunction WithdrawSection({ u }) {\n  const [amt,setAmt]=useState(null);\n  const [pw,setPw]  =useState(\"\");\n  const [err,setErr]=useState(\"\");\n  const [ok,setOk]  =useState(\"\");\n\n  const today=new Date();\n  const dow=today.getDay(); // 0=Sun,6=Sat\n  const dom=today.getDate();\n  const isWeekend=dow===0||dow===6;\n  const isWDay=u.days?.includes(dom);\n\n  const doWithdraw=()=\u003e{\n    setErr(\"\");setOk(\"\");\n    if(isWeekend){setErr(\"Withdrawals are not available on weekends.\");return;}\n    if(!isWDay){setErr(`Today (${dom}) is not a withdrawal day. Your days: ${u.days?.join(\", \")||\"none\"}`);return;}\n    if(!amt){setErr(\"Select withdrawal amount\");return;}\n    if(pw!==u.wp){setErr(\"Incorrect withdrawal password\");return;}\n    if(amt\u003eu.balance){setErr(\"Insufficient balance\");return;}\n    u.setBalance(b=\u003eb-amt);\n    setOk(`Ō£ō Withdrawal of ${fmt(amt)} ETB submitted to CBE ${u.cbe}. Processed in 24ŌĆō72 hours.`);\n    setPw(\"\");setAmt(null);\n  };\n\n  return (\n    \u003c\u003e\n      {isWeekend\u0026\u0026(\n        \u003cGCard style={{marginBottom:14,background:\"rgba(239,68,68,0.06)\",borderColor:\"rgba(239,68,68,0.2)\",textAlign:\"center\",padding:24}}\u003e\n          \u003cdiv style={{fontSize:32,marginBottom:8}}\u003e­¤Ü½\u003c/div\u003e\n          \u003cdiv style={{color:C.red,fontWeight:700,fontSize:14,letterSpacing:1}}\u003eWEEKEND ŌĆö NO WITHDRAWALS\u003c/div\u003e\n          \u003cdiv style={{color:\"#888\",fontSize:11,marginTop:6}}\u003eWithdrawals are weekdays only (MonŌĆōFri)\u003c/div\u003e\n        \u003c/GCard\u003e\n      )}\n\n      \u003cGCard style={{marginBottom:14,background:\"linear-gradient(135deg,rgba(0,229,255,0.07),rgba(0,0,0,0))\"}}\u003e\n        \u003cdiv style={{fontSize:10,color:\"#888\",letterSpacing:2}}\u003eCURRENT BALANCE\u003c/div\u003e\n        \u003cdiv style={{fontFamily:\"'Orbitron',sans-serif\",fontSize:28,fontWeight:900,color:C.cyan,marginTop:2}}\u003e\n          {fmt(u.balance)} \u003cspan style={{fontSize:14}}\u003eETB\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{fontSize:11,color:\"#666\",marginTop:8}}\u003e\n          CBE Account: \u003cspan style={{color:\"#ccc\"}}\u003e{u.cbe||\"Not set\"}\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{fontSize:11,color:\"#666\",marginTop:4}}\u003e\n          Withdrawal days: \u003cspan st