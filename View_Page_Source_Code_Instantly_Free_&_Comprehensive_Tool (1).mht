\",boxShadow:`0 0 10px ${C.cyan}`}}/\u003e\n        \u003c/div\u003e\n        \u003cdiv style={{color:C.cyan,fontSize:10,textAlign:\"center\",marginTop:6,opacity:0.7,letterSpacing:2}}\u003e\n          {prog\u003c100?\"LOADING...\":\"READY\"}\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n}\n\n// ŌöĆŌöĆŌöĆ REGISTER ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ\nfunction RegisterScreen({ onComplete }) {\n  const [step,setStep]   = useState(1);\n  const [phone,setPhone] = useState(\"\");\n  const [lp,setLp]       = useState(\"\");\n  const [lp2,setLp2]     = useState(\"\");\n  const [wp,setWp]       = useState(\"\");\n  const [cbe,setCbe]     = useState(\"\");\n  const [days,setDays]   = useState([]);\n  const [err,setErr]     = useState(\"\");\n\n  const toggleDay = (d) =\u003e {\n    setErr(\"\");\n    if(days.includes(d)){ setDays(days.filter(x=\u003ex!==d)); return; }\n    if(days.length\u003e=3){ setErr(\"Max 3 withdrawal days allowed\"); return; }\n    for(const x of days){\n      const diff=Math.abs(x-d); const gap=Math.min(diff,31-diff);\n      if(gap\u003c6){ setErr(\"Days must be at least 6 days apart\"); return; }\n    }\n    setDays([...days,d].sort((a,b)=\u003ea-b));\n  };\n\n  const s1ok = phone.length\u003e=9 \u0026\u0026 lp.length\u003e=6 \u0026\u0026 lp===lp2;\n  const s2ok = wp.length\u003e=6 \u0026\u0026 cbe.replace(/\\s/g,\"\").length\u003e=10;\n  const s3ok = days.length\u003e=1;\n\n  const base = {\n    width:\"100%\",maxWidth:430,minHeight:\"100vh\",margin:\"0 auto\",\n    background:\"linear-gradient(160deg,#060b14 0%,#0a1628 60%,#060b14 100%)\",\n    fontFamily:\"'Rajdhani',sans-serif\",color:\"#fff\",\n    display:\"flex\",flexDirection:\"column\",alignItems:\"center\",\n    padding:\"40px 24px\",boxSizing:\"border-box\",\n  };\n  return (\n    \u003cdiv style={bas